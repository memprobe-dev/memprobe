.env
.env.*
!.env.example
*.pem
*.key
secrets.json
local_settings.py

# ─── Django ───────────────────────────────────────────────────────────────
*.sqlite3
*.sqlite3-journal
*.db
db.sqlite3-shm
db.sqlite3-wal
# Collected static output (source `static/` stays tracked).
staticfiles/
collected_static/
# User-uploaded media.
media/
# Per-user history DB referenced by MEMPROBE_DB_PATH default.
.memprobe/

# ─── Logs ─────────────────────────────────────────────────────────────────
*.log
logs/
celerybeat-schedule
celerybeat.pid

