.cache
nosetests.xml

# ─── Virtual environments ─────────────────────────────────────────────────
venv/
.venv/
env/
.env-venv/
ENV/
env.bak/
venv.bak/
.python-version

# ─── Secrets / local config ───────────────────────────────────────────────
