<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>memprobe diff - {{ old_basename }} → {{ new_basename }}</title>
<style>
  :root {
    --bg: #1a1a1e; --bg2: #25252b; --bg3: #2e2e36; --border: #3a3a45;
    --text: #e8e8f0; --text2: #9898a8; --accent: #378ADD;
    --green: #1D9E75; --red: #D85A30; --amber: #BA7517;
    --font: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace;
  }
  @media (prefers-color-scheme: light) {
    :root { --bg:#f5f5f7; --bg2:#fff; --bg3:#ebebef; --border:#d0d0d8; --text:#1a1a2e; --text2:#5a5a6a; }
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background:var(--bg); color:var(--text); font-family:var(--font); font-size:14px; line-height:1.5; }
  .container { max-width:1100px; margin:0 auto; padding:0 24px; }
  header { background:var(--bg2); border-bottom:1px solid var(--border); padding:20px 0; }
  header h1 { font-size:20px; }
  .subtitle { color:var(--text2); font-size:13px; font-family:monospace; }
  .delta-row { display:flex; gap:20px; margin-top:14px; flex-wrap:wrap; }
  .delta-card { background:var(--bg3); border:1px solid var(--border); border-radius:8px; padding:12px 20px; }
  .delta-card .label { color:var(--text2); font-size:12px; text-transform:uppercase; letter-spacing:.05em; }
  .delta-card .value { font-size:24px; font-weight:700; }
  .pos { color:var(--red); } .neg { color:var(--green); } .zero { color:var(--text2); }
  main { padding:28px 0; }
  section.card { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:20px; margin-bottom:20px; }
  section.card h2 { font-size:15px; color:var(--text2); text-transform:uppercase; letter-spacing:.08em; margin-bottom:16px; }
  .table-controls { display:flex; gap:12px; margin-bottom:12px; flex-wrap:wrap; }
  input[type=search], select {
    background:var(--bg3); border:1px solid var(--border); color:var(--text);
    padding:7px 12px; border-radius:6px; font-size:13px; outline:none;
  }
  input[type=search] { flex:1; min-width:200px; }
  input[type=search]:focus, select:focus { border-color:var(--accent); }
  .table-wrap { overflow-x:auto; }
  table { width:100%; border-collapse:collapse; font-size:13px; }
  th { background:var(--bg3); color:var(--text2); text-align:left; padding:8px 12px; cursor:pointer; user-select:none; white-space:nowrap; position:sticky; top:0; }
  th:hover { color:var(--text); }
  td { padding:7px 12px; border-top:1px solid var(--border); }
  tr:hover td { background:var(--bg3); }
  .added { color:var(--green); } .removed { color:var(--red); } .changed { color:var(--amber); }
  .tag { display:inline-block; padding:1px 7px; border-radius:10px; font-size:11px; font-weight:600; }
  .tag-added { background:#0d3d28; color:#1D9E75; }
  .tag-removed { background:#3d1410; color:#D85A30; }
  .tag-changed { background:#3d2a00; color:#BA7517; }
  .paginator { display:flex; gap:8px; align-items:center; justify-content:flex-end; margin-top:12px; color:var(--text2); font-size:13px; }
  .paginator button { background:var(--bg3); border:1px solid var(--border); color:var(--text); padding:4px 12px; border-radius:5px; cursor:pointer; }
  .paginator button:hover { border-color:var(--accent); }
  .paginator button:disabled { opacity:.4; cursor:default; }
  footer { text-align:center; color:var(--text2); font-size:12px; padding:20px 0; border-top:1px solid var(--border); margin-top:12px; }
</style>
</head>
<body>
<header>
  <div class="container">
    <h1>memprobe diff</h1>
    <div class="subtitle">{{ old_basename }} → {{ new_basename }}</div>
    <div class="delta-row">
      <div class="delta-card">
        <div class="label">Flash Δ</div>
        <div class="value {% if flash_delta > 0 %}pos{% elif flash_delta < 0 %}neg{% else %}zero{% endif %}">
          {{ '+' if flash_delta > 0 else '' }}{{ "{:,}".format(flash_delta) }} B
        </div>
        <div style="color:var(--text2);font-size:12px">{{ flash_delta_human }}</div>
      </div>
      <div class="delta-card">
        <div class="label">RAM Δ</div>
        <div class="value {% if ram_delta > 0 %}pos{% elif ram_delta < 0 %}neg{% else %}zero{% endif %}">
          {{ '+' if ram_delta > 0 else '' }}{{ "{:,}".format(ram_delta) }} B
        </div>
        <div style="color:var(--text2);font-size:12px">{{ ram_delta_human }}</div>
      </div>
      <div class="delta-card">
        <div class="label">Changed</div>
        <div class="value">{{ diff.symbol_diffs | length }}</div>
        <div style="color:var(--text2);font-size:12px">symbols</div>
      </div>
    </div>
  </div>
</header>

<main>
  <div class="container">
    <section class="card">
      <h2>Symbol Changes</h2>
      <div class="table-controls">
        <input type="search" id="sym-search" placeholder="Search symbols…">
        <select id="kind-filter">
          <option value="">All changes</option>
          <option value="added">Added</option>
          <option value="removed">Removed</option>
          <option value="changed">Changed</option>
        </select>
      </div>
      <div class="table-wrap">
        <table id="diff-table">
          <thead>
            <tr>
              <th data-col="kind">Kind</th>
              <th data-col="name">Symbol</th>
              <th data-col="old_size">Old</th>
              <th data-col="new_size">New</th>
              <th data-col="delta" class="sorted">Delta ↓</th>
              <th data-col="object_file">Object File</th>
            </tr>
          </thead>
          <tbody id="diff-tbody"></tbody>
        </table>
      </div>
      <div class="paginator">
        <span id="page-info"></span>
        <button id="btn-prev" onclick="changePage(-1)">‹ Prev</button>
        <button id="btn-next" onclick="changePage(1)">Next ›</button>
      </div>
    </section>
  </div>
</main>
<footer>Generated by memprobe v{{ version }} - {{ generated_at }}</footer>

<script>
const DIFFS = {{ diffs_json }};
let filtered = [...DIFFS];
let sortCol = 'delta', sortDir = -1;
let page = 0;
const PAGE_SIZE = 50;

function kindOf(d) {
  if (d.old_size === 0) return 'added';
  if (d.new_size === 0) return 'removed';
  return 'changed';
}

function renderTable() {
  const q = document.getElementById('sym-search').value.toLowerCase();
  const kf = document.getElementById('kind-filter').value;
  filtered = DIFFS.filter(d => {
    if (kf && kindOf(d) !== kf) return false;
    if (q && !d.name.toLowerCase().includes(q) && !d.object_file.toLowerCase().includes(q)) return false;
    return true;
  });
  filtered.sort((a, b) => {
    let av = a[sortCol], bv = b[sortCol];
    if (sortCol === 'delta') { av = Math.abs(av); bv = Math.abs(bv); }
    return sortDir * (av > bv ? 1 : av < bv ? -1 : 0);
  });
  const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
  if (page >= totalPages) page = totalPages - 1;
  const slice = filtered.slice(page * PAGE_SIZE, (page + 1) * PAGE_SIZE);
  const tbody = document.getElementById('diff-tbody');
  tbody.innerHTML = '';
  slice.forEach(d => {
    const kind = kindOf(d);
    const sign = d.delta >= 0 ? '+' : '';
    const deltaClass = d.delta > 0 ? 'pos' : d.delta < 0 ? 'neg' : 'zero';
    const tr = document.createElement('tr');
    tr.innerHTML = `
      <td><span class="tag tag-${kind}">${kind}</span></td>
      <td style="font-family:monospace">${esc(d.name)}</td>
      <td style="color:var(--text2)">${d.old_size ? d.old_size.toLocaleString() : '-'}</td>
      <td style="color:var(--text2)">${d.new_size ? d.new_size.toLocaleString() : '-'}</td>
      <td class="${deltaClass}" style="font-weight:600">${sign}${d.delta.toLocaleString()}</td>
      <td style="color:var(--text2);font-size:12px">${esc(d.object_file)}</td>
    `;
    tbody.appendChild(tr);
  });
  document.getElementById('page-info').textContent =
    `${page * PAGE_SIZE + 1}–${Math.min((page + 1) * PAGE_SIZE, filtered.length)} of ${filtered.length}`;
  document.getElementById('btn-prev').disabled = page === 0;
  document.getElementById('btn-next').disabled = page >= totalPages - 1;
}

function changePage(d) { page += d; renderTable(); }
document.getElementById('sym-search').addEventListener('input', () => { page = 0; renderTable(); });
document.getElementById('kind-filter').addEventListener('change', () => { page = 0; renderTable(); });
document.querySelectorAll('#diff-table th[data-col]').forEach(th => {
  th.addEventListener('click', () => {
    const col = th.dataset.col;
    if (sortCol === col) { sortDir *= -1; }
    else { sortCol = col; sortDir = -1; }
    sortCol = col;
    document.querySelectorAll('#diff-table th').forEach(h => h.classList.remove('sorted'));
    th.classList.add('sorted');
    th.textContent = th.textContent.replace(/[↑↓↕]/g, '').trim() + ' ' + (sortDir === 1 ? '↑' : '↓');
    page = 0; renderTable();
  });
});
renderTable();

function esc(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
</script>
</body>
</html>
