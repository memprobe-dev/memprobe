# ── Required in production ────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=your-secret-key-here

# Set to "true" only for local development
DJANGO_DEBUG=false

# Comma-separated list of allowed hostnames in production
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── OAuth credentials ─────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
#   Redirect URI: https://yourdomain.com/accounts/google/login/callback/
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub: https://github.com/settings/developers → New OAuth App
#   Callback URL: https://yourdomain.com/accounts/github/login/callback/
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Optional ──────────────────────────────────────────────────────────────────
# Path to the memprobe build history SQLite database (default: website/data/memprobe.db)
# MEMPROBE_DB_PATH=/path/to/memprobe.db

# Comma-separated allowed CORS origins in production (default: none)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
